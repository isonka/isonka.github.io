# Cache-Control headers for Netlify/Vercel/Modern hosting
# This file optimizes caching for static assets

# Homepage discovery links for AI agents (RFC 8288 / RFC 9727)
/
  Link: </.well-known/api-catalog>; rel="api-catalog"
  Link: </llms.txt>; rel="service-doc"; type="text/plain"

/index.html
  Link: </.well-known/api-catalog>; rel="api-catalog"
  Link: </llms.txt>; rel="service-doc"; type="text/plain"
  Vary: Accept

/index.md
  Content-Type: text/markdown; charset=UTF-8
  X-Markdown-Tokens: available
  Vary: Accept

/.well-known/api-catalog
  Content-Type: application/linkset+json; charset=UTF-8

/.well-known/openid-configuration
  Content-Type: application/json; charset=UTF-8

/.well-known/oauth-authorization-server
  Content-Type: application/json; charset=UTF-8

/.well-known/oauth-protected-resource
  Content-Type: application/json; charset=UTF-8

/.well-known/mcp/server-card.json
  Content-Type: application/json; charset=UTF-8

/.well-known/agent-skills/index.json
  Content-Type: application/json; charset=UTF-8

# HTML files - short cache (1 hour) with revalidation
/*.html
  Cache-Control: public, max-age=3600, must-revalidate

# CSS and JavaScript - long cache (1 year) due to content hashing
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

# Images - long cache (1 year)
/assets/images/*
  Cache-Control: public, max-age=31536000, immutable

# Videos - long cache (1 year)
/assets/video/*
  Cache-Control: public, max-age=31536000, immutable

# Fonts - long cache (1 year)
/assets/fonts/*
  Cache-Control: public, max-age=31536000, immutable
  Access-Control-Allow-Origin: *

# Sitemap and robots - short cache (1 day)
/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

# Service worker (if added later) - no cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# Manifest
/manifest.json
  Cache-Control: public, max-age=604800

